{% import (TextFacade) from "../../../../../lib/control/text-facade" %}
{% import (Demo) from "../../widgets/demo" %}

{% view TextFacadePageView (TextFacadePage from ".") %}
<Demo>
  <Demo>
    <TextFacade> It was a choice.</TextFacade>
  </Demo>
  <Demo>
    <TextFacade disabled=true>Disabled</TextFacade>
  </Demo>
  <Demo>
    <TextFacade className="-block">
     <b>This is just a Facade!</b>
    </TextFacade>
  </Demo>
  <Demo>
    <TextFacade label="With a label">Labelled facade</TextFacade>
  </Demo>
  <Demo>
    <TextFacade
      label="Error state"
      error="This field has an error.">Error facade</TextFacade>
  </Demo>
  <Demo>
    <TextFacade
      label="Warning state"
      warning="This field has a warning.">Warning facade</TextFacade>
  </Demo>
  <Demo>
    <TextFacade
      label="Success state"
      success="This field is valid.">Success facade</TextFacade>
  </Demo>
  <Demo>
    <TextFacade
      wml:id={{@values.programmatic.id}}
      label="Programmatic (click to cycle messages)"
      onClick={{@values.programmatic.onClick}}>Click me</TextFacade>
  </Demo>
</Demo>
